public abstract class Piece {
    protected boolean isWhite;
    protected int x, y; // Current position on the grid

    public Piece(boolean isWhite, int x, int y) {
        this.isWhite = isWhite;
        this.x = x;
        this.y = y;
    }

    public boolean isWhite() { return isWhite; }
    public boolean isBlack() { return !isWhite; }
    
    public void setPosition(int x, int y) {
        this.x = x;
        this.y = y;
    }

    // Every piece (King, Rook, etc.) must implement this math
    public abstract boolean isValidMove(Board board, int endX, int endY);
}
