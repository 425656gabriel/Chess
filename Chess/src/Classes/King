public class King extends Piece {
    public King(Color color, Position position) {
        super(color, position);
    }

    @Override
    public boolean isValidMove(Position newPosition, Board board) {
        int xDiff = Math.abs(newPosition.getX() - this.position.getX());
        int yDiff = Math.abs(newPosition.getY() - this.position.getY());
        
        // Basic King Move: 1 square in any direction
        if (xDiff <= 1 && yDiff <= 1) {
            return !board.isSquareAttacked(newPosition, this.color.opposite());
        }
        // Add castling logic here
        return false;
    }
}

