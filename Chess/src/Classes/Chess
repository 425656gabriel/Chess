import javax.swing.*;
import java.awt.*;
import java.awt.event.*;

// --- PIECE OBJECTS WITH REQUIRED METHODS ---
abstract class Piece {
    protected int r, c;
    protected boolean isWhite;
    protected String type;

    public Piece(boolean isWhite, int r, int c, String type) {
        this.isWhite = isWhite; this.r = r; this.c = c; this.type = type;
    }

    // OBJECTIVE: Functional display() method
    public void display(JButton button) {
        button.setText((isWhite ? "W" : "B") + type);
        button.setFont(new Font("Arial", Font.BOLD, 20));
        button.setForeground(isWhite ? Color.BLUE : Color.RED);
    }

    // OBJECTIVE: Behavioral move() method
    public void move(int newR, int newC) {
        this.r = newR;
        this.c = newC;
    }

    public abstract boolean isValidMove(int er, int ec, Piece[][] board);
}

class King extends Piece {
    public King(boolean isW, int r, int c) { super(isW, r, c, "K"); }
    public boolean isValidMove(int er, int ec, Piece[][] b) {
        return Math.abs(er - r) <= 1 && Math.abs(ec - c) <= 1;
    }
}

class Queen extends Piece {
    public Queen(boolean isW, int r, int c) { super(isW, r, c, "Q"); }
    public boolean isValidMove(int er, int ec, Piece[][] b) {
        int rDiff = Math.abs(er - r), cDiff = Math.abs(ec - c);
        if (r == er || c == ec || rDiff == cDiff) {
            // Path checking logic inside the object behavior
            int rStep = Integer.compare(er, r), cStep = Integer.compare(ec, c);
            int currR = r + rStep, currC = c + cStep;
            while (currR != er || currC != ec) {
                if (b[currR][currC] != null) return false;
                currR += rStep; currC += cStep;
            }
            return true;
        }
        return false;
    }
}

// --- BOARD & CHESS ENTRY POINT ---
public class Board extends JFrame implements ActionListener {
    private JButton[][] buttons = new JButton[8][8];
    private Piece[][] logicBoard = new Piece[8][8]; // OBJECTIVE: Collection of Objects
    private boolean whiteTurn = true;
    private Piece selectedPiece = null;

    public Board() {
        setTitle("Chess - White's Turn");
        setSize(600, 600);
        setDefaultCloseOperation(EXIT_ON_CLOSE);
        JPanel grid = new JPanel(new GridLayout(8, 8));

        for (int r = 0; r < 8; r++) {
            for (int c = 0; c < 8; c++) {
                buttons[r][c] = new JButton();
                if ((r + c) % 2 == 0) buttons[r][c].setBackground(Color.WHITE);
                else buttons[r][c].setBackground(new Color(119, 148, 85));
                buttons[r][c].addActionListener(this);
                grid.add(buttons[r][c]);
            }
        }
        setupBoard();
        add(grid);
        setVisible(true);
    }

    private void setupBoard() {
        // OBJECTIVE: Object Instantiation
        logicBoard[0][4] = new King(false, 0, 4);
        logicBoard[0][3] = new Queen(false, 0, 3);
        logicBoard[7][4] = new King(true, 7, 4);
        logicBoard[7][3] = new Queen(true, 7, 3);
        updateUI();
    }

    @Override
    public void actionPerformed(ActionEvent e) {
        JButton clicked = (JButton) e.getSource();
        int r = -1, c = -1;
        for(int i=0; i<8; i++) for(int j=0; j<8; j++) if(buttons[i][j] == clicked) { r=i; c=j; }

        if (selectedPiece == null) {
            Piece p = logicBoard[r][c];
            if (p != null && p.isWhite == whiteTurn) {
                selectedPiece = p;
                buttons[r][c].setBorder(BorderFactory.createLineBorder(Color.YELLOW, 4));
            }
        } else {
            if (selectedPiece.isValidMove(r, c, logicBoard)) {
                Piece target = logicBoard[r][c];
                // Opposing color check
                if (target == null || target.isWhite != selectedPiece.isWhite) {
                    executeLogicMove(selectedPiece, r, c);
                }
            }
            selectedPiece = null;
            updateUI();
        }
    }

    private void executeLogicMove(Piece p, int nr, int nc) {
        int oldR = p.r, oldC = p.c;
        Piece temp = logicBoard[nr][nc];
        
        logicBoard[oldR][oldC] = null;
        p.move(nr, nc); // OBJECTIVE: Behavioral move call
        logicBoard[nr][nc] = p;

        if (isCheck(whiteTurn)) {
            p.move(oldR, oldC); // Undo move
            logicBoard[oldR][oldC] = p;
            logicBoard[nr][nc] = temp;
            JOptionPane.showMessageDialog(this, "Illegal: King in Check!");
        } else {
            whiteTurn = !whiteTurn;
            setTitle("Chess - " + (whiteTurn ? "White's Turn" : "Black's Turn"));
        }
    }

    public boolean isCheck(boolean white) {
        int kr = -1, kc = -1;
        for(int i=0; i<8; i++) for(int j=0; j<8; j++) 
            if(logicBoard[i][j] instanceof King && logicBoard[i][j].isWhite == white) { kr=i; kc=j; }
        
        for(int i=0; i<8; i++) for(int j=0; j<8; j++) {
            Piece enemy = logicBoard[i][j];
            if (enemy != null && enemy.isWhite != white) 
                if (enemy.isValidMove(kr, kc, logicBoard)) return true;
        }
        return false;
    }

    private void updateUI() {
        for (int i = 0; i < 8; i++) {
            for (int j = 0; j < 8; j++) {
                buttons[i][j].setText("");
                buttons[i][j].setBorder(null);
                if (logicBoard[i][j] != null) logicBoard[i][j].display(buttons[i][j]); // OBJECTIVE: Functional display call
            }
        }
    }

    // OBJECTIVE: Runnable entry point
    public static void main(String[] args) { new Board(); }
}
