import javax.swing.*;
import java.awt.*;

public class Board extends JFrame {
    private JButton[][] buttons = new JButton[8][8];
    private Piece[][] logicBoard = new Piece[8][8]; // Stores the actual King objects

    public Board() {
        setTitle("Chess Game");
        setSize(600, 600);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        JPanel grid = new JPanel(new GridLayout(8, 8));

        for (int r = 0; r < 8; r++) {
            for (int c = 0; c < 8; c++) {
                buttons[r][c] = new JButton();
                
                // Classic Green/White theme
                if ((r + c) % 2 == 0) buttons[r][c].setBackground(Color.WHITE);
                else buttons[r][c].setBackground(new Color(119, 148, 85));
                
                buttons[r][c].setOpaque(true);
                buttons[r][c].setBorderPainted(false);
                grid.add(buttons[r][c]);
            }
        }

        // Place the Kings in the logic array and update the buttons
        setupInitialPieces();

        add(grid);
        setVisible(true);
    }

    private void setupInitialPieces() {
        // Black King at top
        logicBoard[0][4] = new King(false, 0, 4);
        buttons[0][4].setText("BK"); // Placeholder for an icon
        
        // White King at bottom
        logicBoard[7][4] = new King(true, 7, 4);
        buttons[7][4].setText("WK");
    }

    // Helper method so the King can "see" other pieces
    public Piece getPieceAt(int x, int y) {
        return logicBoard[x][y];
    }

    public static void main(String[] args) {
        new Board();
    }
}
